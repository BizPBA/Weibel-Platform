# Production Environment Variables
# Copy this file to .env.production and fill in your production values

# Production Supabase Configuration
VITE_SUPABASE_URL=your-production-supabase-url
VITE_SUPABASE_ANON_KEY=your-production-supabase-anon-key

# Supabase Service Role Key (for migrations - NEVER commit this!)
SUPABASE_SERVICE_ROLE_KEY=your-production-service-role-key
SUPABASE_PROJECT_REF=your-production-project-ref

# Microsoft Azure AD Configuration (Multi-tenant App)
MICROSOFT_CLIENTID=your-azure-app-client-id
MICROSOFT_CLIENTSECRET_VALUE=your-azure-app-client-secret
MICROSOFT_CLIENTSECRET_SECRETID=your-azure-app-secret-id

# Frontend-accessible Microsoft credentials
VITE_MICROSOFT_CLIENTID=your-azure-app-client-id
VITE_MICROSOFT_CLIENTSECRET_VALUE=your-azure-app-client-secret

# Netlify Configuration
NETLIFY_SITE_ID=your-netlify-site-id
NETLIFY_AUTH_TOKEN=your-netlify-auth-token
